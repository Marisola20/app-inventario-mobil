{
  "expo": {
    "name": "Inventario Proenergim",
    "slug": "inventario-proenergim",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "inventario-proenergim",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F766E"
      },
      "permissions": [
        "CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Permite usar la camara para escanear codigos de productos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
